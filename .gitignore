# ═══════════════════════════════════════════
# .gitignore — Oracle RAC DBA Lab
# ═══════════════════════════════════════════

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Binaries and large files
*.zip
*.tar.gz
*.iso
*.vdi
*.vmdk
*.ova
*.rpm

# Oracle Software (installers are too large for git)
software/

# Oracle Install Logs & Temp
oraInventory/
*.log

# Sensitive files (wallets, keys)
*.wallet
*.p12
*.jks
cwallet.sso
ewallet.p12

# Vagrant
.vagrant/
vagrant_rac_dataguard/.vagrant/

# IDE
.vscode/
.idea/

# Old/backup files
vecchio/
guida.zip/
en/

# Temp files
*.tmp
*.bak
*.swp
*.swo
*~
*.old

# Python
__pycache__/
*.pyc
.env

#!/usr/bin/env bash
set -euo pipefail

input="$(cat)"
if [[ "${ORACLE_SID:-RACDB1}" == "RACDB_STBY1" ]]; then
  db_unique_name="RACDB_STBY"
  database_role="PHYSICAL STANDBY"
  instance_status="MOUNTED"
else
  db_unique_name="RACDB"
  database_role="PRIMARY"
  instance_status="OPEN"
fi

if [[ "$input" == *"CLEANUP_GATE"* ]]; then
  echo "DB_UNIQUE_NAME=${db_unique_name}"
  echo "DATABASE_ROLE=${database_role}"
  echo "LEVEL0_COUNT=2"
  echo "CONTROLFILE_COUNT=2"
  echo "SPFILE_COUNT=2"
  echo "ARCHIVELOG_GAP_COUNT=0"
  echo "APPLY_LAG_OK=YES"
elif [[ "$input" == *"INSTANCE_STATUS="* ]]; then
  echo "INSTANCE_STATUS=${instance_status}"
  echo "LOG_MODE=ARCHIVELOG"
  echo "DATABASE_ROLE=${database_role}"
  echo "DB_UNIQUE_NAME=${db_unique_name}"
elif [[ "$input" == *"status || '|' || log_mode"* ]]; then
  echo "OPEN|ARCHIVELOG"
elif [[ "$input" == *"v\$recovery_file_dest"* ]]; then
  echo "35"
elif [[ "$input" == *"v\$diag_alert_ext"* ]]; then
  echo "19-APR 07:00 | ORA-00000 mock entry"
elif [[ "$input" == *"dba_tablespace_usage_metrics"* ]]; then
  echo "USERS 10.0 20.0 50.0"
elif [[ "$input" == *"v\$asm_diskgroup"* ]]; then
  echo "DATA EXTERN 100000 50000 50.0"
elif [[ "$input" == *"v\$rman_backup_job_details"* ]]; then
  echo "DB FULL COMPLETED 19-APR 01:00 19-APR 02:00"
elif [[ "$input" == *"v\$dataguard_stats"* ]]; then
  echo "transport lag 0 seconds now"
elif [[ "$input" == *"v\$session"* ]]; then
  echo "Active sessions: 5"
  echo "Blocking sessions: 0"
else
  echo "sqlplus mock output"
fi

#!/usr/bin/env bash
set -euo pipefail

log_file=""
for arg in "$@"; do
  case "${arg}" in
    log=*|LOG=*) log_file="${arg#*=}" ;;
  esac
done

input="$(cat)"
if [[ "${input}" == *"DELETE NOPROMPT"* ]]; then
  output="deleted RMAN-eligible objects after cleanup gate"
elif [[ "${input}" == *"RESTORE DATABASE VALIDATE"* || "${input}" == *"RESTORE ARCHIVELOG"* ]]; then
  output="Finished restore at 19-APR-26"
elif [[ "${input}" == *"BACKUP AS COMPRESSED"* ]]; then
  output="backup piece created"
else
  output="RMAN report completed"
fi

if [[ -n "${log_file}" ]]; then
  mkdir -p "$(dirname "${log_file}")"
  printf '%s\n' "${output}" >>"${log_file}"
fi
printf '%s\n' "${output}"

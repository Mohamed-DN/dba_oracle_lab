# RMAN backup configuration for SHAMS production primary.
# Copy as: cfg/rman_backup_M24SHAMSPEP.conf
# Do not store passwords here. Use OS authentication and wallet aliases.

ORACLE_HOME=<ORACLE_HOME>
ORACLE_BASE=<ORACLE_BASE>
ORACLE_SID=M24SHAMSPEP
ORACLE_UNQNAME=M24SHAMSPEP

BCKDIR=/backup/rman/M24SHAMSPEP
BCKDIR_MOUNTPOINT=/backup/rman
REQUIRE_BCKDIR_MOUNT=YES

RMAN_CATALOG_CONNECT=/@RMAN_CATALOG
RMAN_TARGET_CONNECT=/

# Production policy A: full/incremental run only while this DB is PRIMARY.
# For standby-offload policy, set this to NEVER and set the SEP config to STANDBY.
EXEC_DATAFILE_BACKUP_WHEN=PRIMARY

PARALLEL_CHANNELS=4
SECTION_SIZE=32G
ARCHIVELOG_FROM_TIME="SYSDATE - 4/24"
LOG_RETENTION_DAYS=30
IGNORE_RMAN_ERRORS="RMAN-08137"

# Optional mail recipient for failures. Leave empty to disable mail.
MAIL_TO=

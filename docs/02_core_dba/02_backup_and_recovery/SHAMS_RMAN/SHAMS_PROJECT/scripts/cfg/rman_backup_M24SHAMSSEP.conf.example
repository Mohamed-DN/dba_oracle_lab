# RMAN backup configuration for SHAMS production standby.
# Copy as: cfg/rman_backup_M24SHAMSSEP.conf
# Do not store passwords here. Use OS authentication and wallet aliases.

ORACLE_HOME=<ORACLE_HOME>
ORACLE_BASE=<ORACLE_BASE>
ORACLE_SID=M24SHAMSSEP
ORACLE_UNQNAME=M24SHAMSSEP

BCKDIR=/backup/rman/M24SHAMSSEP
BCKDIR_MOUNTPOINT=/backup/rman
REQUIRE_BCKDIR_MOUNT=YES

RMAN_CATALOG_CONNECT=/@RMAN_CATALOG
RMAN_TARGET_CONNECT=/

# Production policy A: no full/incremental on standby; archivelog job can still run.
# For standby-offload policy, set this to STANDBY and set PEP config to NEVER.
EXEC_DATAFILE_BACKUP_WHEN=NEVER

PARALLEL_CHANNELS=4
SECTION_SIZE=32G
ARCHIVELOG_FROM_TIME="SYSDATE - 4/24"
LOG_RETENTION_DAYS=30
IGNORE_RMAN_ERRORS="RMAN-08137"

# Optional mail recipient for failures. Leave empty to disable mail.
MAIL_TO=

# RMAN backup configuration for one DB_UNIQUE_NAME.
# Copy as: cfg/rman_backup_<DB_UNIQUE_NAME>.conf
# Do not store passwords here. Use OS authentication and wallet aliases.

ORACLE_HOME=<ORACLE_HOME>
ORACLE_BASE=<ORACLE_BASE>
ORACLE_SID=<LOCAL_ORACLE_SID>
ORACLE_UNQNAME=<DB_UNIQUE_NAME>

BCKDIR=/backup/rman/<DB_UNIQUE_NAME>
BCKDIR_MOUNTPOINT=/backup/rman
REQUIRE_BCKDIR_MOUNT=YES
RMAN_CATALOG_CONNECT=/@<RMAN_CATALOG_TNS_ALIAS>
RMAN_TARGET_CONNECT=/

# DATAFILE backup policy:
#   ALWAYS  = run datafile backup on this host regardless of role
#   PRIMARY = run datafile backup only when database_role is PRIMARY
#   STANDBY = run datafile backup only when database_role is PHYSICAL STANDBY
#   NEVER   = do not run full/cumulative/differential; archivelog still runs
EXEC_DATAFILE_BACKUP_WHEN=STANDBY

PARALLEL_CHANNELS=4
SECTION_SIZE=32G
ARCHIVELOG_FROM_TIME="SYSDATE - 4/24"
LOG_RETENTION_DAYS=30
IGNORE_RMAN_ERRORS="RMAN-08137"

# Optional mail recipient for failures. Leave empty to disable mail.
MAIL_TO=

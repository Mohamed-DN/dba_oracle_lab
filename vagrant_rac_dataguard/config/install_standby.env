export DOMAIN_NAME=localdomain

export NODE1_HOSTNAME=racstby1
export NODE2_HOSTNAME=racstby2
export NODE1_FQ_HOSTNAME=${NODE1_HOSTNAME}.${DOMAIN_NAME}
export NODE2_FQ_HOSTNAME=${NODE2_HOSTNAME}.${DOMAIN_NAME}

export NODE1_VIPNAME=${NODE1_HOSTNAME}-vip
export NODE2_VIPNAME=${NODE2_HOSTNAME}-vip
export NODE1_FQ_VIPNAME=${NODE1_VIPNAME}.${DOMAIN_NAME}
export NODE2_FQ_VIPNAME=${NODE2_VIPNAME}.${DOMAIN_NAME}

export NODE1_PRIVNAME=${NODE1_HOSTNAME}-priv
export NODE2_PRIVNAME=${NODE2_HOSTNAME}-priv
export NODE1_FQ_PRIVNAME=${NODE1_PRIVNAME}.${DOMAIN_NAME}
export NODE2_FQ_PRIVNAME=${NODE2_PRIVNAME}.${DOMAIN_NAME}

export PUBLIC_SUBNET=192.168.56.0
export PRIVATE_SUBNET=192.168.2.0

export DNS_PUBLIC_IP=192.168.56.50
export NODE1_PUBLIC_IP=192.168.56.111
export NODE2_PUBLIC_IP=192.168.56.112
export NODE1_PRIV_IP=192.168.2.111
export NODE2_PRIV_IP=192.168.2.112
export NODE1_VIP_IP=192.168.56.113
export NODE2_VIP_IP=192.168.56.114

export SCAN_IP_1=192.168.56.115
export SCAN_IP_2=192.168.56.116
export SCAN_IP_3=192.168.56.117

export ORACLE_BASE=/u01/app/oracle
export ORA_INVENTORY=/u01/app/oraInventory
export GRID_HOME=/u01/app/19.0.0/grid
export DB_HOME_EXT=product/19.0.0/dbhome_1

export ORACLE_UNQNAME=RACDB_STBY
export PDB_NAME=PDB1
export NODE1_ORACLE_SID=RACDB_STBY1
export NODE2_ORACLE_SID=RACDB_STBY2
export ORACLE_TERM=xterm

export ORA_LANGUAGES=en,en_GB
export SCAN_NAME=racstby-scan
export FQ_SCAN_NAME=${SCAN_NAME}.${DOMAIN_NAME}
export SCAN_PORT=1521
export CLUSTER_NAME=racstby-cluster

export ROOT_PASSWORD=oracle
export ORACLE_PASSWORD=oracle
export SYS_PASSWORD=oracle
export PDB_PASSWORD=oracle

export GRID_SOFTWARE=LINUX.X64_193000_grid_home.zip
export DB_SOFTWARE=LINUX.X64_193000_db_home.zip

NET_DEVICE1=`ip a | grep "eth1" | grep "BROADCAST" | cut -d":" -f2 | awk '{print $1}'`
export NET_DEVICE1=${NET_DEVICE1:-eth1}

NET_DEVICE2=`ip a | grep "eth2" | grep "BROADCAST" | cut -d":" -f2 | awk '{print $1}'`
export NET_DEVICE2=${NET_DEVICE2:-eth2}
